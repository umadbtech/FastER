<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FastER" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color (Navy Blue) -->
        <item name="colorPrimary">@color/navy_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/navy_blue_light</item>
        <item name="colorOnPrimaryContainer">@color/navy_blue</item>

        <!-- Secondary Brand Color (Emergency Red) -->
        <item name="colorSecondary">@color/emergency_red</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/emergency_red_light</item>
        <item name="colorOnSecondaryContainer">@color/emergency_red</item>

        <!-- Background & Surface (Light/White for day mode) -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorOnBackground">@color/grey</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">@color/light_grey</item>
        <item name="colorOnSurfaceVariant">@color/grey_800</item>
        <item name="colorOutline">@color/grey_800</item>

        <!-- Status Bar (Light mode = dark status bar icons) -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Error -->
        <item name="colorError">@color/emergency_red</item>
        <item name="colorOnError">@color/white</item>
    </style>
</resources>
